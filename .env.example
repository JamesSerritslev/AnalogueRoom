# Resend — host event inquiry API (`/api/host-inquiry`)
RESEND_API_KEY=
RESEND_FROM=
# Comma-separated staff inboxes (all receive the same inquiry email)
HOST_INQUIRY_TO_EMAIL=

# Sanity (public)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# Required in Vercel env vars; tells Sanity Presentation where the site lives.
# On Vercel: set to https://your-project.vercel.app (or custom domain).
# Locally: leave as http://localhost:3000.
# (NEXT_PUBLIC_VERCEL_URL is a Vercel auto-inject; no need to set it manually.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Navbar “Coming Soon” pill: hidden when set exactly to false (any other unset value keeps it visible).
# NEXT_PUBLIC_COMING_SOON=false

# One-time seed: `npm run seed:pages`; Editor token from sanity.io/manage (do not commit)
# SANITY_API_TOKEN=
# Visual Editing / Presentation (server-only)
# SANITY_API_READ_TOKEN=
# Mapbox (public)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Mailchimp: newsletter API
MAILCHIMP_SERVER=
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
